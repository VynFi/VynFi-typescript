{
  "name": "vynfi",
  "version": "0.1.0",
  "description": "Official TypeScript/JavaScript client for the VynFi synthetic financial data API",
  "author": "VynFi <hello@vynfi.com>",
  "license": "Apache-2.0",
  "homepage": "https://vynfi.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/VynFi/VynFi-typescript.git"
  },
  "keywords": [
    "vynfi",
    "synthetic-data",
    "finance",
    "api",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0",
    "@typescript-eslint/parser": "^8.0",
    "eslint": "^9.0",
    "msw": "^2.12.10",
    "tsup": "^8.4",
    "typescript": "^5.7",
    "vitest": "^3.0"
  }
}
